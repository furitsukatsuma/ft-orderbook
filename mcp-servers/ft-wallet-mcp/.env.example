# ft-wallet-mcp — 環境変数
# .gitignore に必ず含めること！（秘密はサーバ側のみ。クライアントへ出さない）

# 汎用 Webhook 通知（URL 1つで Slack / Discord / 任意の Webhook に届く）
#   Slack   : Incoming Webhook URL をそのまま貼る（payload.text を表示）
#   Discord : チャンネルの Webhook URL を貼る（payload.content を表示）
#   その他  : title / message / event / meta を受け取る独自エンドポイントでも可
NOTIFY_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# 板ツールのバックエンド: supabase | sqlite
#   未指定なら SUPABASE_URL + SUPABASE_SERVICE_KEY があれば supabase、無ければ sqlite。
# FT_WALLET_BACKEND=supabase

# Supabase（板/承認データの正本。supabase バックエンド時に必須）。
#   管理UI（orderbook-admin）と同一プロジェクトを指すこと。
# SUPABASE_URL=https://YOUR-REF.supabase.co
# SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# DB の保存先（sqlite バックエンド時。省略時は ../../data/ft_wallet.db）
# FT_WALLET_DB_PATH=/abs/path/to/ft_wallet.db

# Stripe（将来の本番決済用。今はなくてもOK）
# STRIPE_SECRET_KEY=sk_live_xxxx
